# ===================================================
# Casedance 环境配置文件
# 部署步骤：cp .env.example .env 然后编辑 .env 填入真实值
# ===================================================

# Django 核心
SECRET_KEY=请生成随机字符串替换此处
DEBUG=True
SITE_CLOSE=False
ALLOWED_HOSTS=*
BASE_URL=http://127.0.0.1:8000

# MySQL 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=casedance
DB_USER=root
DB_PASSWORD=请填写数据库密码

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# SuperBed 图床
SUPERBED_TOKEN=请填写SuperBed Token

# eBay API (生产环境必填)
EBAY_CLIENT_ID=请填写eBay Client ID
EBAY_CLIENT_SECRET=请填写eBay Client Secret

# 盛德物流认证（可运行时通过 /api/sd_cookies_setting 更新）
SD_COOKIES=请填写盛德物流Token

# Dify AI 发票识别
DIFY_INVOICE_APIKEY=请填写Dify API Key
DIFY_HOST=请填写Dify服务地址
