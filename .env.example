# ===================================================
# Casedance 环境配置 · .env
# 从 .env.example 复制并填入真实值
# ===================================================

# Django 核心
SECRET_KEY=请生成随机字符串
DEBUG=True
ALLOWED_HOSTS=*
BASE_URL=http://127.0.0.1:8000

# MySQL 数据库
DB_NAME=casedance
DB_USER=root
DB_PASSWORD=请填写数据库密码

# Redis
REDIS_CACHE_DB=1

# SuperBed 图床
SUPERBED_TOKEN=请填写
CDN_RATE_LIMIT_PER_HOUR=1000

# eBay API
EBAY_CLIENT_ID=请填写
EBAY_CLIENT_SECRET=请填写

# 盛德物流
SD_COOKIES=请填写

# Dify AI
DIFY_INVOICE_APIKEY=请填写
DIFY_EBAY_APIKEY=请填写
DIFY_HOST=请填写

# 飞书（可留空）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 服务器 IP/域名（nginx 配置用）
SERVER_NAME=请填写服务器IP或域名
